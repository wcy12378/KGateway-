# KAgent 基础配置
KAGENT_DEBUG=false
KAGENT_LLM_PROVIDER=deepseek
# 仅本地开发开启；生产环境必须关闭并接入真实 SSO/OAuth。
KAGENT_ALLOW_DEV_TOKENS=true

# 至少配置一个 LLM Provider
KAGENT_DEEPSEEK_API_KEY=
KAGENT_DEEPSEEK_MODEL=deepseek-chat
KAGENT_OPENAI_API_KEY=
KAGENT_OPENAI_MODEL=gpt-4o-mini
KAGENT_GEMINI_API_KEY=
KAGENT_GEMINI_MODEL=gemini-2.0-flash

# 基础设施
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kagent_vectors
REDIS_URL=redis://localhost:6379
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# 生产环境必须替换为至少 32 字节的强随机密钥
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# 请求限流（按客户端 IP，公开路由除外）
KAGENT_RATE_LIMIT_ENABLED=true
KAGENT_RATE_LIMIT_PER_MINUTE=30

# 可选：Server-to-Server 认证；为空时不启用 API Key 认证
KAGENT_API_KEY=

# 工具调用审计日志最多保留条数
KAGENT_AUDIT_MAX_ENTRIES=1000

# 多 Provider 自动路由策略：priority 或 latency
KAGENT_ROUTING_STRATEGY=priority

# 交互延迟优化
KAGENT_EMBEDDING_WARMUP=true
KAGENT_CACHE_TIMEOUT_MS=300
KAGENT_CACHE_NAMESPACE_VERSION=v1
KAGENT_INTERACTIVE_MAX_TOKENS=512
KAGENT_FAST_PATH_ENABLED=true
KAGENT_FAQ_PATH=config/faq.json

# 可选：name:command:arg1|arg2;name2:command2:arg1
KAGENT_MCP_SERVERS=

# 可选：Langfuse 可观测平台
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
